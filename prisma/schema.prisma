generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Party {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  adminPassword String
  matchingDone  Boolean  @default(false)
  createdAt     DateTime @default(now())
  guests        Guest[]
}

model Guest {
  id          String   @id @default(cuid())
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id])
  name        String
  photoUrl    String?
  answers     String
  matchedWith String?
  matchNote   String?
  createdAt   DateTime @default(now())
}

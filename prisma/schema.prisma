generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Party {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  adminPassword   String
  matchingDone    Boolean  @default(false)
  customQuestions String?
  settings        String?
  createdAt       DateTime @default(now())
  guests          Guest[]
}

model QuestionSet {
  id        String   @id @default(cuid())
  name      String
  questions String   // JSON array of Question objects
  createdAt DateTime @default(now())
}

model Guest {
  id          String   @id @default(cuid())
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id])
  name        String
  gender      String?
  photoUrl    String?
  answers     String
  matchedWith String?
  matchNote   String?
  createdAt   DateTime @default(now())
}
